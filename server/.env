# ===========================
# AI / LLM
# ===========================
AI_API_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# ===========================
# Push Notifications (VAPID)
# ===========================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@byteful.io

# ===========================
# File Uploads
# ===========================
UPLOAD_PATH=uploads
MAX_FILE_SIZE=10485760
MAX_FILES=10

# ===========================
# Bull Board (Queue Dashboard)
# ===========================
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=admin
BULL_CONCURRENCY=5

# ===========================
# Logging
# ===========================
