# ===========================
# App
# ===========================
NODE_ENV=development
PORT=4000
APP_NAME=skeleton-app
APP_VERSION=1.0.0
APP_URL=http://localhost:4000
BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================
# Database (MySQL)
# ===========================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=sam2
DB_PASSWORD=sam123
DB_NAME=email_tool
# Optional: set true only for local auto schema sync (risks deadlocks if multiple processes run). Prefer migrations.
DB_SYNCHRONIZE=false

# ===========================
# JWT
# ===========================
JWT_SECRET=your-jwt-secret-change-this
JWT_ACCESS_TOKEN_EXPIRATION=15m
JWT_REFRESH_TOKEN_EXPIRATION=7d

# ===========================
# Redis
# ===========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================
# Google OAuth
# ===========================
GOOGLE_CLIENT_ID=0294u294u9024294909420942
GOOGLE_CLIENT_SECRET=4024809820480284829429
